{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2022"
    ]
  },
  "exclude": [
    "./node_modules",
    "./dist"
  ],
  "$schema": "./.vscode/tsconfig.schema.json"
}