{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "outDir": "./electron-dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/electron/main/**/*.ts",
    "src/electron/preload/**/*.ts",
    "src/agent/core/**/*.ts",
    "src/agent/llm/**/*.ts",
    "src/agent/tools/**/*.ts",
    "src/agent/context/**/*.ts",
    "src/agent/utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/electron/renderer"
  ]
}
