{
  "name": "smartagent",
  "version": "1.0.0",
  "description": "SmartAgent CLI",
  "main": "dist/cli/index.js",
  "type": "module",
  "bin": {
    "agent": "./dist/cli/index.js"
  },
  "scripts": {
    "test:error": "tsx tests/error-handler.test.ts",
    "test:error:debug": "tsx --inspect-brk tests/error-handler.test.ts",
    "test:env-check": "tsx tests/env-check.test.ts",
    "test:env-check:debug": "tsx --inspect-brk tests/env-check.test.ts",
    "test:logger": "tsx tests/logger.test.ts",
    "test:logger:debug": "tsx --inspect-brk tests/logger.test.ts",
    "test:context": "tsx tests/context-aware.test.ts",
    "test:context:debug": "tsx --inspect-brk tests/context-aware.test.ts",
    "test:table": "tsx tests/table.test.ts",
    "test:table:debug": "tsx --inspect-brk tests/table.test.ts",
    "test:config": "tsx tests/config-manager.test.ts",
    "test:config:debug": "tsx --inspect-brk tests/config-manager.test.ts",
    "test:commands": "tsx tests/advanced-commands.test.ts",
    "test:commands:debug": "tsx --inspect-brk tests/advanced-commands.test.ts",
    "test:autocomplete": "tsx tests/autocomplete.test.ts",
    "test:autocomplete:debug": "tsx --inspect-brk tests/autocomplete.test.ts",
    "test:retry": "tsx tests/retry.test.ts",
    "test:retry:debug": "tsx --inspect-brk tests/retry.test.ts",
    "test:progress": "tsx tests/progress.test.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli/index.js",
    "cli": "tsx src/cli/index.ts",
    "dev": "nodemon --watch src --ext ts --exec tsx src/cli/index.ts",
    "debug": "node --inspect-brk -r tsx/cjs src/cli/index.ts",
    "debug:start": "tsx --inspect-brk src/cli/index.ts"
  },
  "keywords": [
    "cli",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.23",
    "@types/node": "^25.9.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "listr2": "^10.2.1",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "table": "^6.9.0",
    "zod": "^4.4.3"
  }
}
