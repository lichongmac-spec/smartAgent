{
  "name": "smartagent",
  "version": "1.0.0",
  "description": "SmartAgent CLI",
  "main": "dist/cli/index.js",
  "type": "module",
  "bin": {
    "agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli/index.js",
    "cli": "tsx src/cli/index.ts",
    "dev": "nodemon --watch src --ext ts --exec tsx src/cli/index.ts",
    "debug": "node --inspect-brk -r tsx/cjs src/cli/index.ts",
    "debug:start": "tsx --inspect-brk src/cli/index.ts"
  },
  "keywords": [
    "cli",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.23",
    "@types/node": "^25.9.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  }
}
